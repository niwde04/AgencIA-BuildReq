# ============================================================
# BuildReq - Variables de Entorno (Ejemplo)
# Copia este archivo como .env y completa los valores
# ============================================================

PORT=3000

# Base de datos PostgreSQL (Supabase)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# Cookie secret (string largo y seguro, mínimo 32 chars)
JWT_SECRET=cambia-esto-por-un-string-seguro-de-al-menos-32-chars

# ============================================================
# SUPABASE
# ============================================================
SUPABASE_URL=https://[project-ref].supabase.co

# Settings → API → Secret keys → "default"
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Settings → API → JWT Settings → Legacy JWT Secret
SUPABASE_JWT_SECRET=

# Claves del cliente (públicas)
VITE_SUPABASE_URL=https://[project-ref].supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# ============================================================
# OPCIONALES
# ============================================================
VITE_APP_ID=
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# AWS S3 (adjuntos - opcional)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=buildreq-attachments
