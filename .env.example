# ============================================================
# BuildReq - Variables de Entorno (Desarrollo Local)
# ============================================================

# Puerto del servidor (opcional, default: 4000)
PORT=4000

# Base de datos PostgreSQL (Supabase)
# Supabase → Settings → Database → Connection string → URI (Transaction mode)
DATABASE_URL=postgresql://postgres:tu-password@db.tu-proyecto.supabase.co:5432/postgres

# Auth / JWT (cualquier string largo y seguro)
JWT_SECRET=cambia-esto-por-un-string-seguro-de-al-menos-32-chars

# ============================================================
# SUPABASE
# ============================================================

# URL del proyecto
SUPABASE_URL=https://tu-proyecto.supabase.co

# Secret key → Supabase → Settings → API → Secret keys → "default"
# (la que empieza con sb_secret_... o la legacy service_role eyJ...)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT Secret → Supabase → Settings → API → JWT Settings → "JWT Secret"
SUPABASE_JWT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bucket privado para documentos adjuntos. Se crea automaticamente si no existe.
SUPABASE_STORAGE_BUCKET=buildreq-attachments

# Duracion de las URLs firmadas que devuelve el backend para abrir adjuntos.
SUPABASE_STORAGE_SIGNED_URL_SECONDS=3600

# Claves del cliente (expuestas al frontend - son públicas y seguras)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_SITE_URL=https://buildreq.aibdev.com

# ============================================================
# OPCIONALES (no necesarios en local)
# ============================================================
VITE_APP_ID=
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ============================================================
# DOKPLOY / DOCKER (opcionales)
# ============================================================
# Puerto publicado por docker-compose
APP_PORT=4000

# Si está en true, el contenedor ejecuta pnpm db:push antes de iniciar
RUN_DB_PUSH=false
